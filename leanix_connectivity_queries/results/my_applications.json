  {
    "id": "f34148a7-5a08-4f64-b3e4-5e4d2f53963a",
    "name": "FM Connect",
    "alias": "fm-connect",
    "displayName": "FM Connect",
    "description": "FM Connect is a data engineering solution designed to establish the data foundation necessary to address ITIL Service Asset and Configuration Management (SACM) challenges within the organization. It focuses exclusively on data integration, transformation, and availability to enable a connected enterprise data layer. The solution is responsible for extracting data from siloed systems, standardizing it through well-defined data models, and making it available for consumption by reporting tools, analytics platforms, and potential future applications. This document outlines the technical approach, architecture, and implementation strategy for the FM Connect data engineering solution.",
    "type": "Application",
    "status": "ACTIVE",
